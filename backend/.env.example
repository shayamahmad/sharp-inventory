# ── INVETO: copy to .env — coordinates Frontend + API + MongoDB Compass ─────
# 1) MONGODB_URI → where Mongoose stores data (database name at end = Compass DB name).
# 2) PORT → must match Vite proxy target in frontend/vite.config.ts (default 3001).
# 3) FRONTEND_URL → Vite dev URL (8080); CORS if you use VITE_API_URL=http://localhost:3001.
# Run full stack from repo root: npm run dev:full
# Compass: same connection as MONGODB_URI host/port → open database "inveto".
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
FRONTEND_URL=http://localhost:8080

# Database
# Local MongoDB via Docker (from server/): npm run db:up
# Then: npm run seed   (first time, or npm run seed -- --force to reset)
MONGODB_URI=mongodb://127.0.0.1:27017/inveto

# Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/inveto?retryWrites=true&w=majority

# --- MongoDB Compass (GUI) ---
# Install: https://www.mongodb.com/products/compass
# Local Docker / native MongoDB: New connection → paste:
#   mongodb://127.0.0.1:27017
# Then open the database named "inveto" (collections appear after npm run seed).
# Same URI with auth as in MONGODB_URI also works, e.g. mongodb://127.0.0.1:27017/inveto

JWT_SECRET=change-me-in-production-use-long-random-string

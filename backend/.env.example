# ── INVETO: copy to .env — Frontend + API + MongoDB (Atlas or local) ────────
# 1) MONGODB_URI → Atlas SRV string OR local URI (database name before ? or path = e.g. inveto).
# 2) PORT → must match Vite proxy (default 3001).
# 3) FRONTEND_URL → Vite dev URL (8080).
# Run full stack: npm run dev:full
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
FRONTEND_URL=http://localhost:8080

# ═══ Database: use Atlas OR local — comment one out ═══════════════════════════

# --- MongoDB Atlas (recommended for cloud / team / deploy) ------------------
# 1) https://cloud.mongodb.com → Create (free M0) cluster.
# 2) Database Access → create user (username + password).
# 3) Network Access → Add IP Address → "Allow access from anywhere" (0.0.0.0/0) for dev,
#    or your current IP for stricter access.
# 4) Database → Connect → Drivers → copy the connection string.
# 5) Replace <password> with your user password (URL-encode special chars: @ → %40, etc.).
# 6) Ensure the path ends with your DB name, e.g. ...mongodb.net/inveto?retryWrites=true&w=majority
#
# MONGODB_URI=mongodb+srv://MY_USER:MY_PASSWORD@cluster0.xxxxx.mongodb.net/inveto?retryWrites=true&w=majority

# --- Local MongoDB (Docker: npm run db:up — or native mongod on 27017) --------
MONGODB_URI=mongodb://127.0.0.1:27017/inveto

# ═══════════════════════════════════════════════════════════════════════════

# Seed (Atlas or local): from repo root, npm run seed  — first time or npm run seed -- --force

# MongoDB Compass: paste the SAME string as MONGODB_URI (Atlas SRV or local URI) → open DB "inveto".

JWT_SECRET=change-me-in-production-use-long-random-string

# ── INVETO frontend ↔ backend ↔ MongoDB Compass ─────────────────────────────
# Backend uses backend/.env → MONGODB_URI (e.g. mongodb://127.0.0.1:27017/inveto)
# Compass: connect to that same host/port, then open database "inveto".
# Run stack: from repo root → npm run dev:full  (Vite 8080 + API 3001)
# ─────────────────────────────────────────────────────────────────────────────

# Option A — Vite proxy (recommended): leave empty. Requests go to /api on :8080 → proxied to :3001
VITE_API_URL=

# Option B — call API directly (then set backend FRONTEND_URL to match this dev server):
# VITE_API_URL=http://localhost:3001

# Inveron Copilot (optional — omit both for rule-based answers only)
# VITE_ANTHROPIC_API_KEY=
# VITE_OPENAI_API_KEY=
